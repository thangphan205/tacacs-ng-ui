# ════════════════════════════════════════════════════════════════════════════
# tacacs-ng-ui environment configuration
# Copy this file to .env and fill in values before starting the stack.
# See docs/en/ for detailed setup guides.
# ════════════════════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  QUICK START — Deploy on a server by IP (e.g. 192.168.8.8)             │
# │                                                                         │
# │  Only these 4 values need to change. Everything else keeps its default. │
# │                                                                         │
# │    DOMAIN=192.168.8.8                                                   │
# │    FRONTEND_HOST=http://192.168.8.8:5173                                │
# │    VITE_API_URL=http://192.168.8.8:8000                                 │
# │    SECRET_KEY=<run: openssl rand -hex 32>                               │
# │                                                                         │
# │  Then start the stack (without Traefik):                                │
# │    docker compose up -d                                                 │
# │                                                                         │
# │  Access:                                                                │
# │    Frontend → http://192.168.8.8:5173                                   │
# │    API/Docs → http://192.168.8.8:8000/docs                             │
# │    Adminer  → http://192.168.8.8:8080                                   │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Networking ───────────────────────────────────────────────────────────────

# DOMAIN: base domain used by Traefik for TLS routing and host matching.
#   local dev:  localhost
#   production: yourdomain.com
DOMAIN=localhost

# FRONTEND_HOST: full URL of the frontend — added to CORS allow-list automatically.
#   docker compose dev: http://localhost:5173
#   production:         https://yourdomain.com
FRONTEND_HOST=http://localhost:5173

# VITE_API_URL: URL the browser uses to reach the backend API.
#   Baked into the frontend image at build time (cannot change without rebuilding).
#   Leave blank to auto-derive as https://api.<DOMAIN> (domain-based, Traefik + DNS required).
#   Set explicitly for IP-based deployments or non-standard ports:
#     VITE_API_URL=http://192.168.8.8:8000
#     VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=

# ── Application ──────────────────────────────────────────────────────────────

# ENVIRONMENT: controls debug mode and error verbosity in API responses.
#   local      — debug mode on, full stack traces in error responses
#   staging    — production settings, non-live infra
#   production — hardened: no debug, no stack traces exposed to clients
ENVIRONMENT=local

# PROJECT_NAME: displayed in the UI header and email templates.
PROJECT_NAME="TACACS+ NG UI"

# STACK_NAME: Docker Compose project name (prefix for container/volume names).
#   Change when running multiple stacks on the same host to avoid naming conflicts.
STACK_NAME=tacacs-ng-ui

# ── Core Backend ─────────────────────────────────────────────────────────────

# TZ: timezone used by cron jobs when computing "yesterday" for log file parsing.
#   Must match the timezone of the TACACS+ server that produces the log files.
#   Examples: Asia/Ho_Chi_Minh, UTC, America/New_York, Europe/Berlin
#   See: backend/app/crud/_log_stats_base.py
TZ=Asia/Ho_Chi_Minh

# BACKEND_CORS_ORIGINS: extra origins allowed to call the API from browsers.
#   FRONTEND_HOST is always included automatically — no need to repeat it here.
#   Only add origins that are different from FRONTEND_HOST (e.g. other dev ports, admin tools).
#   Do NOT use wildcard (*) in production.
#   Deploying to 192.168.8.8? Just set FRONTEND_HOST=http://192.168.8.8 — CORS is handled.
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# SECRET_KEY: signs JWT access tokens and HMAC state for OAuth flows.
#   Generate: openssl rand -hex 32
#   Changing this invalidates all existing sessions (all users must re-login).
SECRET_KEY=changethis

# FIRST_SUPERUSER / FIRST_SUPERUSER_PASSWORD: superuser account seeded on first startup.
#   Has no effect after the database is already initialized.
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── TACACS+ Server ───────────────────────────────────────────────────────────

# TACACS_LOG_DIRECTORY: path inside the container where tac_plus-ng writes auth/authz logs.
#   Default matches the path in generated tac_plus-ng config files.
#   Change only if you mount logs to a custom location.
TACACS_LOG_DIRECTORY="/var/log/tacacs/"

# USERS_OPEN_REGISTRATION: allow anyone to self-register a local account via the UI.
#   True  — open sign-up (dev/lab use only)
#   False — only admins can create accounts (recommended for production)
USERS_OPEN_REGISTRATION=True

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for password-reset emails and alert notifications via the email channel.
# Leave SMTP_HOST blank to disable all outbound email.

# SMTP_HOST: hostname of your SMTP relay.
#   local dev:  mailcatcher (docker compose service)
#   production: smtp.gmail.com, smtp.sendgrid.net, etc.
SMTP_HOST=

# SMTP_USER / SMTP_PASSWORD: SMTP AUTH credentials. Leave blank for unauthenticated relays.
SMTP_USER=
SMTP_PASSWORD=

# EMAILS_FROM_EMAIL: sender address shown in all outbound emails.
EMAILS_FROM_EMAIL=info@example.com

# SMTP_TLS: use STARTTLS on connection (standard port 587). Set False when using SMTP_SSL.
SMTP_TLS=True

# SMTP_SSL: use direct TLS/SSL (port 465). Set SMTP_TLS=False when using this.
SMTP_SSL=False

# SMTP_PORT: must match your chosen security mode (25 plain, 587 STARTTLS, 465 SSL).
SMTP_PORT=587

# ── PostgreSQL ───────────────────────────────────────────────────────────────

# POSTGRES_SERVER: hostname of the primary PostgreSQL instance.
#   docker compose: db  (internal service name)
#   external DB:    your DB host or IP
POSTGRES_SERVER=localhost

# POSTGRES_PORT: default 5432. Change if your DB listens on a non-standard port.
POSTGRES_PORT=5432

# POSTGRES_DB: database name. Created automatically on first startup if it doesn't exist.
POSTGRES_DB=app

# POSTGRES_USER: database role used by the backend.
POSTGRES_USER=postgres

# POSTGRES_PASSWORD: use a strong random password in production.
#   Generate: openssl rand -hex 32
POSTGRES_PASSWORD=changethis

# ── Observability ─────────────────────────────────────────────────────────────

# SENTRY_DSN: enable Sentry error tracking. Leave blank to disable.
#   Get from: https://sentry.io → Project → Settings → SDK Setup → DSN
SENTRY_DSN=

# ════════════════════════════════════════════════════════════════════════════
# High Availability (HA) — leave all defaults for single-node deployments
# See docs/en/high-availability.md for full multi-node setup guide.
# ════════════════════════════════════════════════════════════════════════════

# ── Env-only settings (always require restart to change) ─────────────────────

# NODE_ROLE: controls DB write access and scheduler behavior at startup.
#   primary  — read-write DB, runs alert/ML/audit scheduler loops
#   standby  — read-only replica DB, no scheduler (config synced from primary)
#   Changing this requires a restart — it determines whether PostgreSQL accepts writes.
NODE_ROLE=primary

# INTERNAL_SYNC_TOKEN: shared secret for inter-node API calls (config reload + stats collection).
#   Must be identical on all nodes. Generate with: openssl rand -hex 32
#   Never store in the database — env-only for security.
INTERNAL_SYNC_TOKEN=

# ── Seeded settings (written to DB on first primary startup, editable via HA UI) ──
#
# These values are stored in the database the first time the primary starts.
# After that, change them live via High Availability UI — no restart needed.
# The env vars below are ignored after first boot (DB values take precedence).

# NODE_NAME: human-readable label for this node, shown in HA dashboard and AAA statistics.
#   Must be unique per node. Examples: dc1-primary, zone-a, hq-tacacs
NODE_NAME=primary

# SCHEDULER_ENABLED: controls alert evaluation, ML anomaly scoring, and audit log purge.
#   true  — run scheduler loops (set on primary)
#   false — disable scheduler (set on standby nodes)
#   Automatically set to true when a standby is promoted via the UI.
SCHEDULER_ENABLED=true

# SYNC_MODE: how standby nodes receive TACACS+ config changes from the primary.
#   auto   — standby polls DB every 10 s and reloads tac_plus-ng automatically
#   manual — admin clicks "Sync to Standbys" in the dashboard to push config
SYNC_MODE=auto

# STATS_INTERVAL_MINUTES: how often (minutes) the primary collects today's live AAA
#   statistics from all nodes into the database.
#   0 = disable background collection (rely on nightly cron jobs only).
STATS_INTERVAL_MINUTES=30

# ── Peer node bootstrap (seeded into DB on first primary startup) ─────────────
#
# These seed the initial peer node list into the hapeernode table on first boot.
# After that, manage peers via High Availability → Peers in the UI — no restart needed.
# For more than 2 nodes: add additional peers through the UI or /api/v1/sync/peers API.

# PEER_BACKEND_URL: internal API URL of a single standby peer (2-node setups).
#   Seeded as the first peer entry on first primary startup.
#   Example: http://172.25.245.236:8000  or  https://api-b.yourdomain.com
PEER_BACKEND_URL=

# PEER_NODES: comma-separated internal API URLs for multi-node (3+) setups.
#   Seeded as multiple peer entries on first primary startup.
#   Takes precedence over PEER_BACKEND_URL when both are set.
#   Examples:
#     PEER_NODES=http://dc2-standby:8000
#     PEER_NODES=http://dc2-standby:8000,http://dc3-standby:8000
PEER_NODES=

# ── Standby-only settings (only needed when NODE_ROLE=standby) ───────────────

# PRIMARY_DB_HOST: IP of the primary PostgreSQL host.
#   Used by setup-standby.sh to run pg_basebackup for initial replication setup.
#   IP address only — no port, no scheme (e.g. 172.25.245.214).
PRIMARY_DB_HOST=

# REPLICATION_PASSWORD: password for the 'replicator' PostgreSQL role on the primary.
#   Only required on standby nodes during setup-standby.sh.
REPLICATION_PASSWORD=

# ── MAVIS per-zone overrides ──────────────────────────────────────────────────
# Override any MAVIS key stored in the database with a zone-specific value at
# config-generation time. Useful when each zone needs different LDAP/RADIUS endpoints.
# Prefix any MAVIS setting with MAVIS_OVERRIDE_ to apply it only on this node.
# Examples:
# MAVIS_OVERRIDE_LDAP_HOSTS=ldaps://ipa-zone-b.example.com:636
# MAVIS_OVERRIDE_LDAP_USER=uid=svc_tacacs,cn=users,cn=accounts,dc=example,dc=com
# MAVIS_OVERRIDE_RADIUS_HOST=radius.zone-b.example.com

# ── Traefik (docker-compose.traefik.yml) ─────────────────────────────────────
# Only needed when running Traefik as the reverse proxy (production with real domain + Let's Encrypt).
# Not required for local dev (docker-compose.override.yml uses a simple insecure proxy).

# EMAIL: Let's Encrypt contact email for TLS certificate expiry notifications.
EMAIL=

# USERNAME / HASHED_PASSWORD: HTTP Basic Auth for the Traefik dashboard.
#   Generate hash: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
USERNAME=
HASHED_PASSWORD=

# ════════════════════════════════════════════════════════════════════════════
# Docker images
# ════════════════════════════════════════════════════════════════════════════

# Image names used by docker compose. Change to registry paths for production pulls.
# Examples:
#   DOCKER_IMAGE_BACKEND=ghcr.io/yourorg/tacacs-ng-ui-backend:v1.2.3
#   DOCKER_IMAGE_FRONTEND=ghcr.io/yourorg/tacacs-ng-ui-frontend:v1.2.3
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ════════════════════════════════════════════════════════════════════════════
# Authentication Providers (optional — leave blank to disable each provider)
# ════════════════════════════════════════════════════════════════════════════

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Setup: Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   Application type: Web application
#   Authorized redirect URI: <BACKEND_URL>/api/v1/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# ── Keycloak OIDC ─────────────────────────────────────────────────────────────
# Setup: Keycloak Admin → Realm → Clients → Create client
#   Client protocol: openid-connect
#   Access type: confidential
#   Valid redirect URI: <BACKEND_URL>/api/v1/oauth/keycloak/callback
# KEYCLOAK_SERVER_URL: base URL of your Keycloak server (no trailing slash).
KEYCLOAK_SERVER_URL=http://localhost:8080
# KEYCLOAK_REALM: realm name containing the client (avoid using "master" in production).
KEYCLOAK_REALM=tacacs
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Keycloak.
KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/v1/oauth/keycloak/callback
