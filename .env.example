# Domain
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="TACACS+ NG UI"
STACK_NAME=tacacs-ng-ui

# Backend
TZ=Asia/Ho_Chi_Minh
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

TACACS_LOG_DIRECTORY="/var/log/tacacs/"
USERS_OPEN_REGISTRATION=True

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# High Availability (HA) — leave defaults for single-node deployments
# NODE_ROLE: primary (default) or standby
NODE_ROLE=primary
# SCHEDULER_ENABLED: set to false on standby nodes (alerts, ML scoring, audit purge run on primary only)
SCHEDULER_ENABLED=true
# SYNC_MODE: auto = standby auto-reloads config when DB replication delivers changes
#            manual = admin clicks "Sync to Zone B" in dashboard to push config
SYNC_MODE=auto
# PEER_BACKEND_URL: internal URL of the other zone's API (used for config push/health check)
PEER_BACKEND_URL=
# INTERNAL_SYNC_TOKEN: shared secret for inter-node reload calls — must match on both zones
INTERNAL_SYNC_TOKEN=
# PRIMARY_DB_HOST: Zone A DB host — only needed on Zone B during setup-standby.sh
PRIMARY_DB_HOST=
# REPLICATION_PASSWORD: password for the 'replicator' PostgreSQL role — only needed on Zone B
REPLICATION_PASSWORD=
# MAVIS per-zone overrides: override any MAVIS key from DB with a zone-specific value
# Example: point Zone B to its local LDAP server instead of Zone A's
# MAVIS_OVERRIDE_LDAP_HOSTS=ldaps://ipa-zone-b.example.com:636

# Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# Google OAuth (get these from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# Keycloak OIDC (optional — leave blank to disable)
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=tacacs
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/v1/oauth/keycloak/callback
